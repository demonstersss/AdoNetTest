<Window x:Class="WpfApp5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Форма логина (изначально видима) -->
        <StackPanel Grid.Row="0" x:Name="LoginPanel" Margin="10" Orientation="Vertical" HorizontalAlignment="Center">
            <Label Content="Login:" HorizontalAlignment="Center"/>
            <TextBox x:Name="LoginTextBox" Width="200" HorizontalAlignment="Center" Margin="5"/>
            <Label Content="Password:" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="PasswordTextBox" Width="200" HorizontalAlignment="Center" Margin="5"/>
            <Button x:Name="EnterButton" Content="Enter" Click="EnterButton_Click" Margin="5" Padding="10,5" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Основной Grid с кнопками (изначально скрыт) -->
        <Grid x:Name="ButtonsGrid" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Первая строка -->
            <Button x:Name="AddButton" Grid.Row="0" Grid.Column="0" Content="Add" Margin="5" Click="AddButton_Click"/>
            <Button x:Name="DelButton" Grid.Row="0" Grid.Column="1" Content="Del" Margin="5" Click="DelButton_Click"/>
            <Button x:Name="EditButton" Grid.Row="0" Grid.Column="2" Content="Edit" Margin="5" Click="EditButton_Click"/>

            <!-- Вторая строка -->
            <Button x:Name="SellButton" Grid.Row="1" Grid.Column="0" Content="Sell" Margin="5" Click="SellButton_Click"/>
            <Button x:Name="CribButton" Grid.Row="1" Grid.Column="1" Content="Crib" Margin="5" Click="CribButton_Click"/>
            <Button x:Name="SaleButton" Grid.Row="1" Grid.Column="2" Content="Sale" Margin="5" Click="SaleButton_Click"/>

            <!-- Третья строка -->
            <Button x:Name="ToCustomerButton" Grid.Row="2" Grid.Column="0" Content="ToCustomer" Margin="5" Click="ToCustomerButton_Click"/>
            <Button x:Name="SearchButton" Grid.Row="2" Grid.Column="1" Content="Search" Margin="5" Click="SearchButton_Click"/>
            <Button x:Name="ListButton" Grid.Row="2" Grid.Column="2" Content="List" Margin="5" Click="ListButton_Click"/>
        </Grid>
    </Grid>
</Window>