<Window x:Class="WpfApp5.WindowsClasses.EditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.WindowsClasses"
        mc:Ignorable="d"
        Title="EditBookWindow" Height="450" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" Margin="5" Padding="10,5"/>
            <Button x:Name="EditBookButton" Content="Edit" Click="EditBookButton_Click" Margin="5" Padding="10,5"/>
        </StackPanel>

        <DataGrid x:Name="BooksDataGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="True" SelectionMode="Single"/>
        </Grid>
</Window>
