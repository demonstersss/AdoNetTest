<Window x:Class="WpfApp5.WindowsClasses.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.WindowsClasses"
        mc:Ignorable="d"
        Title="SearchWindow" Height="450" Width="800">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
    <Button x:Name="NameButton" Content="Name" Click="NameButton_Click" Margin="5" Padding="20,10" Height="40" Width="150"/>
    <Button x:Name="AuthorButton" Content="Author" Click="AuthorButton_Click" Margin="5" Padding="20,10" Height="40" Width="150"/>
    <Button x:Name="GenreButton" Content="Genre" Click="GenreButton_Click" Margin="5" Padding="20,10" Height="40" Width="150"/>
    </StackPanel>
</Window>
