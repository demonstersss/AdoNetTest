<Window x:Class="WpfApp5.Windows.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.Windows"
        mc:Ignorable="d"
        Title="AddBookWindow" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Title:" VerticalAlignment="Center"/>
            <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="1" Grid.Column="0" Content="AuthorId:" VerticalAlignment="Center"/>
            <TextBox x:Name="AuthorIdTextBox" Grid.Row="1" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="2" Grid.Column="0" Content="PublisherId:" VerticalAlignment="Center"/>
            <TextBox x:Name="PublisherIdTextBox" Grid.Row="2" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="3" Grid.Column="0" Content="Pages:" VerticalAlignment="Center"/>
            <TextBox x:Name="PagesTextBox" Grid.Row="3" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="4" Grid.Column="0" Content="GenreId:" VerticalAlignment="Center"/>
            <TextBox x:Name="GenreIdTextBox" Grid.Row="4" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="5" Grid.Column="0" Content="ReleaseDate:" VerticalAlignment="Center"/>
            <DatePicker x:Name="ReleaseDatePicker" Grid.Row="5" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="6" Grid.Column="0" Content="OriginalPrice:" VerticalAlignment="Center"/>
            <TextBox x:Name="OriginalPriceTextBox" Grid.Row="6" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="7" Grid.Column="0" Content="TotalPrice:" VerticalAlignment="Center"/>
            <TextBox x:Name="TotalPriceTextBox" Grid.Row="7" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="8" Grid.Column="0" Content="PreviousBookId:" VerticalAlignment="Center"/>
            <TextBox x:Name="PreviousBookIdTextBox" Grid.Row="8" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="9" Grid.Column="0" Content="NextBookId:" VerticalAlignment="Center"/>
            <TextBox x:Name="NextBookIdTextBox" Grid.Row="9" Grid.Column="1" Margin="5,0"/>

            <Label Grid.Row="10" Grid.Column="0" Content="Count:" VerticalAlignment="Center"/>
            <TextBox x:Name="CountTextBox" Grid.Row="10" Grid.Column="1" Margin="5,0"/>

            <Button x:Name="AddBookButton" Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Content="Add" Margin="5" Click="AddBookButton_Click" HorizontalAlignment="Center"/>
            <Button x:Name="RefreshButton" Grid.Row="12" Grid.Column="1" Content="Refresh" Margin="5" Click="RefreshButton_Click" HorizontalAlignment="Right"/>
        </Grid>

        <DataGrid x:Name="BooksDataGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="True"/>
    </Grid>
</Window>
