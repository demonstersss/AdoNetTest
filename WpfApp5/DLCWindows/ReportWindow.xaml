<Window x:Class="WpfApp5.DLCWindows.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.DLCWindows"
        mc:Ignorable="d"
        Title="ReportWindow" Height="1000" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <Label x:Name="TopBooksLabel" Content="Самые продаваемые книги" FontWeight="Bold" HorizontalAlignment="Center"/>
            <DataGrid x:Name="TopBooksDataGrid" AutoGenerateColumns="False" CanUserSortColumns="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Книга (Продажи)" Binding="{Binding DisplayText}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10">
            <Label x:Name="TopAuthorsLabel" Content="Самые продаваемые авторы" FontWeight="Bold" HorizontalAlignment="Center"/>
            <DataGrid x:Name="TopAuthorsDataGrid" AutoGenerateColumns="False" CanUserSortColumns="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Автор (Продажи)" Binding="{Binding DisplayText}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10">
            <Label x:Name="TopGenresLabel" Content="Самые продаваемые жанры" FontWeight="Bold" HorizontalAlignment="Center"/>
            <DataGrid x:Name="TopGenresDataGrid" AutoGenerateColumns="False" CanUserSortColumns="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Жанр (Продажи)" Binding="{Binding DisplayText}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="10">
            <Label x:Name="BooksByIdLabel" Content="Новинки" FontWeight="Bold" HorizontalAlignment="Center"/>
            <DataGrid x:Name="BooksByIdDataGrid" AutoGenerateColumns="False" CanUserSortColumns="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Книга (Id)" Binding="{Binding DisplayText}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>
