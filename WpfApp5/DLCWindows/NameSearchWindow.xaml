<Window x:Class="WpfApp5.DLCWindows.NameSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.DLCWindows"
        mc:Ignorable="d"
        Title="NameSearchWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <TextBox x:Name="NameTextBox" Width="200" Margin="5" VerticalContentAlignment="Center"/>
            <Button x:Name="SearchButton" Content="Search" Click="SearchButton_Click" Margin="5" Padding="10,5"/>
        </StackPanel>

        <DataGrid x:Name="BooksDataGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="True" CanUserSortColumns="False"/>
    </Grid>
</Window>
