<Window x:Class="WpfApp5.DLCWindows.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp5.DLCWindows"
        mc:Ignorable="d"
        Title="AddCustomerWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Имя покупателя:" VerticalAlignment="Center"/>
            <TextBox x:Name="CustomerNameTextBox" Grid.Column="1" Margin="5,0" VerticalContentAlignment="Center"/>
            <Button x:Name="SaveButton" Grid.Column="2" Content="Save" Click="SaveButton_Click" Margin="5" Padding="10,5" VerticalAlignment="Center"/>
        </Grid>

        <DataGrid x:Name="CustomersDataGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="True"/>
    </Grid>
</Window>
